# =============================================================================
# PI-Board — configuration (.env)
# Copie ce fichier en `.env` puis renseigne TES valeurs.  `.env` est gitignoré.
# Tout est OPTIONNEL sauf indication : sans valeur, la fonctionnalité se
# désactive proprement (zéro-crash). Minimum pour démarrer = une localisation
# météo + une sortie audio joignable. Tout le reste est progressif.
# =============================================================================

# --- VOIX : reconnaissance (STT) -------------------------------------------
# vosk = local Kaldi FR, gratuit, 0 réseau (DÉFAUT, marche sans rien d'autre)
# nemotron = serveur Nemotron ASR sur le LAN (plus précis) ; Vosk reste le repli
# voxtral / batch = cloud Mistral (nécessite MISTRAL_API_KEY)
STT_MODE=vosk
# Si STT_MODE=nemotron : URL du serveur Nemotron ASR (ex http://IP_DU_SERVEUR:8766)
NEMOTRON_ASR_URL=
NEMOTRON_ASR_TIMEOUT=8

# --- CERVEAU : LLM ----------------------------------------------------------
# gateway = LLM local GRATUIT via une passerelle Ollama sur ton LAN (recommandé)
# mistral = cloud Mistral (payant à l'usage, nécessite MISTRAL_API_KEY)
LLM_PROVIDER=gateway
# Passerelle locale (lan-voice-gateway) : Ollama + TTS sur n'importe quelle
# machine du LAN (un autre PC, un Mac, le Pi lui-même...). Laisse vide pour
# n'utiliser que le routeur de mots-clés (intentions) sans LLM conversationnel.
GATEWAY_URL=
GATEWAY_TOKEN=

# --- VOIX : synthèse (TTS) --------------------------------------------------
# gateway = TTS local via la passerelle (gratuit) | piper = TTS local FR (offline)
# voxtral = cloud Mistral (payant)
TTS_PROVIDER=gateway

# --- Cloud Mistral (repli LLM/TTS/STT optionnel, payant) --------------------
# SECRET — laisse vide si tu restes 100% local.
MISTRAL_API_KEY=

# --- MUSIQUE ----------------------------------------------------------------
# radio = radio internet (radio-browser, GRATUIT, sans compte) — DÉFAUT légal
# local = bibliothèque de fichiers locale (voir MUSIC_LIBRARY_DIR)
# spotify = via l'API Spotify (compte requis)
# deezer = FLAC via ton propre ARL (⚠️ ZONE GRISE des CGU Deezer : usage perso,
#          flux non archivé. Opt-in ; fournis TON propre ARL, jamais commité).
MUSIC_PROVIDER=radio
# Si MUSIC_PROVIDER=local : dossier de la bibliothèque (défaut ~/Music).
MUSIC_LIBRARY_DIR=
# SECRET — ton ARL Deezer perso (compte HiFi pour le FLAC). Opt-in, jamais partagé.
DEEZER_ARL=
DEEZER_QUALITY=FLAC          # FLAC | MP3_320 | MP3_128
# Spotify (si MUSIC_PROVIDER=spotify) — crée une app : developer.spotify.com
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_DEVICE_NAME=PiBoard

# --- MÉTÉO (Open-Meteo, sans clé) -------------------------------------------
# Mets TES coordonnées. (Le fuseau se règle dans l'admin → Météo.)
WEATHER_CITY=Paris
WEATHER_LAT=48.85
WEATHER_LON=2.35

# --- CAMÉRAS UniFi Protect (optionnel) --------------------------------------
# Laisse vide pour désactiver. UNIFI_USER/PASS = SECRETS.
UNIFI_HOST=
UNIFI_USER=
UNIFI_PASS=
UNIFI_MAC=                    # MAC du NVR (survit au DHCP) ; vide = autodétection

# --- ENCEINTES / AUDIO ------------------------------------------------------
# DEVIALET_IP : hostname/IP d'un Devialet Phantom (contrôle volume/EQ par IP).
# Vide = pas de Devialet ; la sortie audio se choisit dans l'admin (n'importe
# quel sink PipeWire : AirPlay, HDMI, Bluetooth, jack...).
DEVIALET_IP=
# Micro : device ALSA (vide = autodétection d'un micro USB type ReSpeaker).
RESPEAKER_DEVICE=

# --- DOMOTIQUE (volets / portail / prises) ----------------------------------
# lite          = drivers intégrés Shelly (Gen1/2/3) + Kasa, sans dépendance — DÉFAUT
# homeassistant = pilote ta domotique via une instance Home Assistant existante
HOME_PROVIDER=lite
# Si HOME_PROVIDER=homeassistant : URL + jeton longue durée (Profil HA → Jetons).
HA_URL=                       # ex http://homeassistant.local:8123
HA_TOKEN=                     # SECRET
# La LISTE de tes appareils ne se met PAS ici : elle vit dans
# backend/admin/config.json -> section "home": { "devices": [ ... ] }
# (registre vide = domotique désactivée proprement). Modèle d'un appareil
# documenté dans backend/services/home/base.py. Exemple lite (Shelly + Kasa) :
#   { "id":"volet_salon", "name":"Volet Salon", "kind":"cover",
#     "driver":"shelly_roller", "mac":"AABBCCDDEEFF" }
#   { "id":"portail", "name":"Portail", "kind":"gate",
#     "driver":"shelly_relay_g3", "shelly_id":"shelly1minig3-xxxx" }
#   { "id":"prise", "name":"Guinguette", "kind":"switch", "driver":"kasa_plug" }
# Exemple Home Assistant : ajoute "ha_entity":"cover.volet_salon" à chaque appareil.

# --- ADMIN ------------------------------------------------------------------
# Un mot de passe admin aléatoire est généré au 1er démarrage et affiché dans
# les logs (plus de mot de passe par défaut livré). Change-le dans l'admin.
