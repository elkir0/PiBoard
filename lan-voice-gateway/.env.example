# Copier en .env et remplir. NE JAMAIS committer .env.
LAN_VOICE_TOKEN=change-me-long-random-token
OLLAMA_URL=http://127.0.0.1:11434
# Gemma 4 12B QAT (Q4_K_XL) servi par Ollama. Alias compat possible : qwen3.5-hermes.
OLLAMA_MODEL=gemma4-12b-qat-q4-k-xl
# 12B plus lourd que l'ancien 9B : marge de timeout (les délais réels côté Pi gouvernent le fallback).
OLLAMA_TIMEOUT=60
OLLAMA_KEEP_ALIVE=30m
# Restreindre au Pi (laisser vide = pas de filtre IP, token seul) :
ALLOWED_IPS=
VOXTRAL_TTS_BASE=$HOME/.hermes/workspace/voxtral-tts
TTS_VOICE_DEFAULT=fr_female
TTS_TEMPERATURE=0.7
